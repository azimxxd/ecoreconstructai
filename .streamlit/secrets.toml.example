# Скопируй этот файл в .streamlit/secrets.toml и заполни свои ключи.

# Hugging Face — бесплатный токен для генерации изображений.
# Создать: https://huggingface.co/settings/tokens (роль: Read)
HF_API_TOKEN = ""

# ---------------------------------------------------------------------------
# Supabase Postgres
# Взять из: Supabase → Project Settings → Database → Connection string (URI)
# Используй Transaction pooler (порт 6543).
# ---------------------------------------------------------------------------
[database]
url = "postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres"

# ---------------------------------------------------------------------------
# Google OAuth (Streamlit OIDC login)
# 1. Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client ID
# 2. Application type: Web application
# 3. Authorized redirect URIs:
#      - http://localhost:8501/oauth2callback         (локально)
#      - https://ВАШ-АПП.streamlit.app/oauth2callback (продакшн)
# 4. cookie_secret: python -c "import secrets; print(secrets.token_hex(32))"
# ---------------------------------------------------------------------------
[auth]
redirect_uri  = "http://localhost:8501/oauth2callback"
cookie_secret = "СЛУЧАЙНАЯ_СТРОКА_НЕ_МЕНЕЕ_32_СИМВОЛОВ"

[auth.google]
client_id     = "XXXXXXXX.apps.googleusercontent.com"
client_secret = "GOCSPX-XXXXXXXX"
server_metadata_url = "https://accounts.google.com/.well-known/openid-configuration"
