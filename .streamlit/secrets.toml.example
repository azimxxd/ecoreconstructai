# Скопируй этот файл в .streamlit/secrets.toml и заполни свои ключи.

# OpenAI — основной движок генерации изображений (gpt-image).
# Ключ: https://platform.openai.com/api-keys  (нужен включённый billing).
# Если не задан — приложение откатывается на бесплатный Hugging Face FLUX.
OPENAI_API_KEY = ""
# Необязательно: модель и качество генерации.
#   OPENAI_IMAGE_MODEL   — например "gpt-image-1" или "gpt-image-2" (по умолч. gpt-image-1)
#   OPENAI_IMAGE_QUALITY — "low" | "medium" | "high" (по умолч. high)
# OPENAI_IMAGE_MODEL = "gpt-image-1"
# OPENAI_IMAGE_QUALITY = "high"

# Hugging Face — бесплатный фолбэк для генерации изображений.
# Создать: https://huggingface.co/settings/tokens (роль: Read)
HF_API_TOKEN = ""

# ---------------------------------------------------------------------------
# Supabase Postgres
# Взять из: Supabase → Project Settings → Database → Connection string (URI)
# Для постоянного приложения (Streamlit) используй Session pooler (порт 5432) —
# выделенная сессия на соединение, стабильно работает с клиентским пулом.
# Transaction pooler (6543) — для serverless/edge-функций.
# ---------------------------------------------------------------------------
[database]
url = "postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres"

# ---------------------------------------------------------------------------
# Аутентификация
# Регистрация и вход выполняются по имени пользователя + паролю (пароль
# хранится в виде PBKDF2-хеша в таблице users). Никаких внешних провайдеров
# (Google OAuth и т.п.) настраивать НЕ нужно.
#
# secret_key — ключ для подписи cookie «оставаться в системе» (вход
# переживает перезагрузку страницы). Необязателен: если не задан, ключ
# выводится из URL базы. Для продакшна задайте свой:
#   python -c "import secrets; print(secrets.token_hex(32))"
# ---------------------------------------------------------------------------
[app]
secret_key = ""
